# Copy to .env and fill values
# GitHub OAuth App credentials
GH_CLIENT_ID=your_github_oauth_app_client_id
GH_CLIENT_SECRET=your_github_oauth_app_client_secret
# The redirect URI you register in GitHub OAuth App (must match)
REDIRECT_URI=https://yourdomain.com/auth/callback
# Where to redirect back after exchange (your admin path)
ADMIN_UI_BASE=https://yourdomain.com/journey/admin.html
# Optionally override port
PORT=3000
